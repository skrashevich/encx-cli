# Shared VHS settings for encx-cli demo tapes.
# Sourced by each *.tape via: Source config.tape

Set Shell bash
Set FontSize 16
Set Width 1400
Set Height 720
Set Theme "Catppuccin Mocha"
Set TypingSpeed 35ms
Set PlaybackSpeed 1.2
Set Margin 24
Set MarginFill "#1e1e2e"
Set BorderRadius 8
Set WindowBar Colorful
